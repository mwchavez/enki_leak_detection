#include <driver/i2s.h>

#define I2S_WS   25   // LRCL
#define I2S_SD   33   // DOUT
#define I2S_SCK  26   // BCLK

#define I2S_PORT I2S_NUM_0

#define SAMPLE_BUFFER_SIZE 512
int32_t samples[SAMPLE_BUFFER_SIZE];

void setup() {
  Serial.begin(115200);

  // I2S configuration
  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = 16000,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_32BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_I2S,
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 4,
    .dma_buf_len = 256,
    .use_apll = false
  };

  // Pin configuration
  i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_SCK,
    .ws_io_num = I2S_WS,
    .data_out_num = -1,
    .data_in_num = I2S_SD
  };

  // Install driver
  i2s_driver_install(I2S_PORT, &i2s_config, 0, NULL);
  i2s_set_pin(I2S_PORT, &pin_config);
  i2s_zero_dma_buffer(I2S_PORT);

  Serial.println("INMP441 ready...");
}

void loop() {
  size_t bytes_read;

  // Read samples from mic
  i2s_read(I2S_PORT, (void*)samples, sizeof(samples), &bytes_read, portMAX_DELAY);

  int num_samples = bytes_read / 4; // 4 bytes per sample (32-bit)

  long sum = 0;

  // Convert + compute amplitude
  for (int i = 0; i < num_samples; i++) {
    int32_t sample = samples[i] >> 14;  // convert 24-bit to usable range
    sum += abs(sample);
  }

  // Average volume level
  int avg = sum / num_samples;

  Serial.println(avg);

  delay(50);
}
