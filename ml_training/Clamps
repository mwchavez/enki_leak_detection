      Serial.print(" EVENT | ");
      Serial.print(leakLevelLabel(lastPresentedLeakLevel));
      Serial.print(" -> ");
      Serial.println(leakLevelLabel(outputLeakLevel));
      lastPresentedLeakLevel = outputLeakLevel;
    }

    printElapsedPrefix(nowMs);
    Serial.print(PRESENTATION_NODE_LABEL);
    Serial.print(" | ");
    Serial.print(leakLevelLabel(outputLeakLevel));
    Serial.print(" | Sound ");
    Serial.print(features[0], 0);
