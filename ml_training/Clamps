// Convert raw vibration bursts into steadier rule-friendly features.
void updateEngineeredVibrationFeatures(
  float magnitude,
  float activeMean,
  float variance,
  float burstMean
) {
  vibrationMagnitudeFeature = magnitude;
  vibrationMeanFeature = activeMean;
  vibrationVarianceFeature = variance;
  float risingTrend = activeMean - previousVibrationMeanFeature;
  vibrationTrendFeature = risingTrend > 0.0f ? risingTrend : 0.0f;
  vibrationSustainFeature =
    ((1.0f - VIBRATION_SUSTAIN_ALPHA) * vibrationSustainFeature) +
    (VIBRATION_SUSTAIN_ALPHA * burstMean);
  previousVibrationMeanFeature = activeMean;
}
bool vibrationSupportsMedium(
  int vibrationDelta,
  float vibrationMean,
  float vibrationVariance,
  float vibrationTrend,
  float vibrationSustain
) {
  return
    (vibrationMean >= 40.0f) ||
    (vibrationSustain >= 36.0f) ||
    ((vibrationVariance >= 1000.0f) && (vibrationMean >= 30.0f)) ||
    ((vibrationTrend >= 10.0f) && (vibrationDelta >= 120));
}
bool vibrationSupportsLarge(
  int vibrationDelta,
  float vibrationMean,
  float vibrationVariance,
  float vibrationTrend,
  float vibrationSustain
) {
  return
    (vibrationMean >= 70.0f) ||
    (vibrationSustain >= 55.0f) ||
    ((vibrationVariance >= 2500.0f) && (vibrationMean >= 45.0f)) ||
    ((vibrationTrend >= 16.0f) && (vibrationDelta >= 170));
}
bool isClampNormalFlowBaseline(
  float soundLevel,
  float spectralCenter,
  float zeroCrossRate,
  float probability,
  int vibrationDelta,
  float vibrationMean,
  float vibrationSustain
) {
  (void)vibrationDelta;
  (void)vibrationMean;
  (void)vibrationSustain;

  bool acousticMatchesNormalFlow =
    (soundLevel >= CLAMP_FLOW_BASELINE_SOUND_MIN) &&
    (soundLevel <= CLAMP_FLOW_BASELINE_SOUND_MAX) &&
    (spectralCenter >= CLAMP_FLOW_BASELINE_SPECTRAL_MIN) &&
    (spectralCenter <= CLAMP_FLOW_BASELINE_SPECTRAL_MAX) &&
    (zeroCrossRate >= CLAMP_FLOW_BASELINE_ZERO_CROSS_MIN) &&
    (zeroCrossRate <= CLAMP_FLOW_BASELINE_ZERO_CROSS_MAX) &&
    (probability >= CLAMP_FLOW_BASELINE_MODEL_MIN);
  return
    acousticMatchesNormalFlow &&
    (soundLevel < CLAMP_FLOW_BASELINE_ESCAPE_SOUND);
}
bool isClampNearNormalFlowBaseline(
  float soundLevel,
  float spectralCenter,
  float zeroCrossRate,
  float probability,
  float vibrationSustain
) {
  bool acousticNearNormalFlow =
    (soundLevel >= CLAMP_FLOW_NEAR_SOUND_MIN) &&
    (soundLevel <= CLAMP_FLOW_BASELINE_SOUND_MAX) &&
    (spectralCenter >= CLAMP_FLOW_BASELINE_SPECTRAL_MIN) &&
    (spectralCenter <= CLAMP_FLOW_BASELINE_SPECTRAL_MAX) &&
    (zeroCrossRate >= CLAMP_FLOW_NEAR_ZERO_CROSS_MIN) &&
    (zeroCrossRate <= CLAMP_FLOW_BASELINE_ZERO_CROSS_MAX) &&
    (probability >= CLAMP_FLOW_BASELINE_MODEL_MIN) &&
    (soundLevel < CLAMP_FLOW_BASELINE_ESCAPE_SOUND);

  return
    acousticNearNormalFlow &&
    (vibrationSustain < SMALL_LEAK_FLOW_VIBRATION_SUSTAIN);
}
bool isClampLargeLeakInFlow(
  float soundLevel,
  float spectralCenter,
  float zeroCrossRate,
  float probability,
  int vibrationDelta,
  float vibrationMean,
  float vibrationTrend,
  float vibrationSustain
) {
  bool acousticInFlowBand =
    (soundLevel >= CLAMP_FLOW_BASELINE_SOUND_MIN) &&
    (soundLevel <= CLAMP_FLOW_BASELINE_SOUND_MAX) &&
    (spectralCenter >= CLAMP_FLOW_BASELINE_SPECTRAL_MIN) &&
    (spectralCenter <= CLAMP_FLOW_BASELINE_SPECTRAL_MAX) &&
    (zeroCrossRate >= CLAMP_FLOW_NEAR_ZERO_CROSS_MIN) &&
    (zeroCrossRate <= CLAMP_FLOW_BASELINE_ZERO_CROSS_MAX) &&
    (probability >= CLAMP_FLOW_BASELINE_MODEL_MIN) &&
    (soundLevel < CLAMP_FLOW_BASELINE_ESCAPE_SOUND);
  bool strongRisingVibration =
    (vibrationSustain >= LARGE_LEAK_FLOW_VIBRATION_SUSTAIN) &&
    (vibrationMean >= LARGE_LEAK_FLOW_VIBRATION_MEAN) &&
    (vibrationTrend >= LARGE_LEAK_FLOW_VIBRATION_TREND);
  bool fastRisingVibration =
    (vibrationSustain >= LARGE_LEAK_FLOW_FAST_RISE_SUSTAIN) &&
    (vibrationMean >= LARGE_LEAK_FLOW_FAST_RISE_MEAN) &&
    (vibrationTrend >= LARGE_LEAK_FLOW_FAST_RISE_TREND) &&
    (vibrationDelta >= LARGE_LEAK_FLOW_FAST_RISE_DELTA);
  bool highTextureHeavyVibration =
    (spectralCenter >= LARGE_LEAK_FLOW_HIGH_TEXTURE_SPECTRAL) &&
    (zeroCrossRate >= LARGE_LEAK_FLOW_HIGH_TEXTURE_ZERO_CROSS) &&
    (vibrationSustain >= LARGE_LEAK_FLOW_HIGH_TEXTURE_SUSTAIN) &&
    (vibrationMean >= LARGE_LEAK_FLOW_VIBRATION_MEAN) &&
    (vibrationDelta >= LARGE_LEAK_FLOW_HIGH_TEXTURE_DELTA);
  bool lowTextureJetVibration =
    (zeroCrossRate <= LARGE_LEAK_FLOW_LOW_ZERO_CROSS_MAX) &&
    (vibrationSustain >= LARGE_LEAK_FLOW_VIBRATION_SUSTAIN) &&
    (vibrationMean >= LARGE_LEAK_FLOW_VIBRATION_MEAN) &&
    (vibrationDelta >= LARGE_LEAK_FLOW_LOW_ZERO_DELTA);

  return
    acousticInFlowBand &&
    (strongRisingVibration || fastRisingVibration || highTextureHeavyVibration || lowTextureJetVibration);
}
