LeakLevel classifyLeakLevel(
  float soundLevel,
  float spectralCenter,
  float zeroCrossRate,
  float probability,
  int vibrationDelta,
  float vibrationMean,
  float vibrationVariance,
  float vibrationTrend,
  float vibrationSustain
) {
  bool vibrationMediumSupport = vibrationSupportsMedium(
    vibrationDelta,
    vibrationMean,
    vibrationVariance,
    vibrationTrend,
    vibrationSustain
  );
  bool vibrationLargeSupport = vibrationSupportsLarge(
    vibrationDelta,
    vibrationMean,
    vibrationVariance,
    vibrationTrend,
    vibrationSustain
  );
  if (isClampLargeLeakInFlow(
    soundLevel,
    spectralCenter,
    zeroCrossRate,
    probability,
    vibrationDelta,
    vibrationMean,
    vibrationTrend,
    vibrationSustain
  )) {
    return LEAK_LEVEL_LARGE;
  }
  if (isClampSmallLeakInFlow(
    soundLevel,
    spectralCenter,
    zeroCrossRate,
    probability,
    vibrationSustain
  )) {
    return LEAK_LEVEL_SMALL;
  }
  if (isClampNormalFlowBaseline(
    soundLevel,
    spectralCenter,
    zeroCrossRate,
    probability,
    vibrationDelta,
    vibrationMean,
    vibrationSustain
  )) {
    return LEAK_LEVEL_NONE;
  }
  if (isClampNearNormalFlowBaseline(
    soundLevel,
    spectralCenter,
    zeroCrossRate,
    probability,
    vibrationSustain
  )) {
    return LEAK_LEVEL_NONE;
  }
  // threshold: early large pattern at 16k/2800/0.19/0.80 or 19k/2550/0.20/0.60
  bool largeTransitionPattern =
    (
      (soundLevel >= 16000.0f) &&
      (spectralCenter >= 2800.0f) &&
      (zeroCrossRate >= 0.19f) &&
      (probability >= 0.80f)
    ) ||
    (
      (soundLevel >= 19000.0f) &&
      (spectralCenter >= 2550.0f) &&
      (zeroCrossRate >= 0.20f) &&
      (probability >= 0.60f)
    );
  // Order matters here: strong special cases are checked before the medium band.
  // Small leak: narrow whistle pattern seen in the bench logs.
  if (
    (soundLevel >= SMALL_LEAK_WHISTLE_SOUND_LEVEL) &&
    (soundLevel < 22000.0f) &&
    (spectralCenter >= SMALL_LEAK_WHISTLE_SPECTRAL_CENTER) &&
    (zeroCrossRate >= 0.28f) &&
    (probability >= SMALL_LEAK_WHISTLE_MODEL_THRESHOLD) &&
    (vibrationDelta < 180)
  ) {
    return LEAK_LEVEL_SMALL;
  }
  // Small leak: reserve red for clear whistle-like signatures, not broad airflow noise.
  if (
    (soundLevel >= 14500.0f) &&
    (soundLevel < 22000.0f) &&
    (spectralCenter >= 2800.0f) &&
    (zeroCrossRate >= 0.24f) &&
    (probability >= 0.97f) &&
    (vibrationDelta < 180) &&
    !vibrationLargeSupport
  ) {
    return LEAK_LEVEL_SMALL;
  }
  // Large leak: reserve blue for the strongest events instead of letting
  // vibration alone promote medium leaks to large.
  if (
    (
      (soundLevel >= LARGE_LEAK_SOUND_LEVEL) &&
      (probability >= 0.95f) &&
      (zeroCrossRate >= 0.14f) &&
      (spectralCenter >= 2200.0f)
    ) ||
    (
      (soundLevel >= LARGE_LEAK_ASSIST_SOUND_LEVEL) &&
      (vibrationDelta >= LARGE_LEAK_VIBRATION_DELTA) &&
      (spectralCenter >= 2200.0f) &&
      (zeroCrossRate >= 0.12f) &&
      (probability >= 0.75f)
    ) ||
    (
      (soundLevel >= 22000.0f) &&
      (spectralCenter >= 2900.0f) &&
      (probability >= 0.98f)
    ) ||
    (
      (soundLevel >= 15000.0f) &&
      (spectralCenter >= 2500.0f) &&
      (zeroCrossRate >= 0.19f) &&
      (probability >= 0.75f) &&
      vibrationLargeSupport
    ) ||
    largeTransitionPattern
  ) {
    return LEAK_LEVEL_LARGE;
  }
  // Medium leak: confirmed leaks with solid energy in the normal working band.
  if (
    (
      (soundLevel >= 15000.0f) &&
      (spectralCenter >= 2400.0f) &&
      (zeroCrossRate >= 0.16f) &&
      (probability >= 0.88f)
    ) ||
    (
      (soundLevel >= 12500.0f) &&
      (spectralCenter >= 2300.0f) &&
      (zeroCrossRate >= 0.16f) &&
      (probability >= 0.82f) &&
      vibrationMediumSupport
    ) ||
    (
      (soundLevel >= 13500.0f) &&
      (spectralCenter >= 2150.0f) &&
      (zeroCrossRate >= 0.16f) &&
      (probability >= 0.70f) &&
      (vibrationDelta >= 180) &&
      !largeTransitionPattern
    )
  ) {
    return LEAK_LEVEL_MEDIUM;
  }
  return LEAK_LEVEL_NONE;
}
