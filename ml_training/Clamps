// Read one audio window, remove DC offset, and convert to 16-bit samples.
bool readMicWindow() {
  size_t bytes_read = 0;
  esp_err_t result = i2s_read(
    I2S_PORT,
    raw_samples,
    sizeof(raw_samples),
    &bytes_read,
    portMAX_DELAY
  );
  if (result != ESP_OK || bytes_read != sizeof(raw_samples)) {
    return false;
  }
  long long sum = 0;
  for (int i = 0; i < WINDOW_SAMPLES; i++) {
    sum += raw_samples[i];
  }
  int32_t mean = (int32_t)(sum / WINDOW_SAMPLES);
  clippedSampleCount = 0;
  for (int i = 0; i < WINDOW_SAMPLES; i++) {
    int32_t centered = raw_samples[i] - mean;
    int32_t shifted = centered >> 8;
    if (shifted > 32767) shifted = 32767;
    if (shifted < -32768) shifted = -32768;
    audio_i16[i] = (int16_t)shifted;
    if (abs((int)audio_i16[i]) >= 32760) {
      clippedSampleCount++;
    }
  }
  return true;
}
float computeRms(const int16_t* audio) {
  double sum_sq = 0.0;
  for (int i = 0; i < WINDOW_SAMPLES; i++) {
    double value = (double)audio[i];
    sum_sq += value * value;
  }
  return (float)sqrt(sum_sq / WINDOW_SAMPLES + 1e-12);
}
float computeZeroCrossingRate(const int16_t* audio) {
  int crossings = 0;
  for (int i = 1; i < WINDOW_SAMPLES; i++) {
    bool prev = audio[i - 1] >= 0;
    bool curr = audio[i] >= 0;
    if (prev != curr) {
      crossings++;
    }
  }
  return (float)crossings / (float)(WINDOW_SAMPLES - 1);
}
// Build simple frequency features used by both the model and the leak rules.
void computeSpectralFeatures(
  const int16_t* audio,
  float& peak_frequency_hz,
  float& spectral_centroid_hz,
  float& low_band_energy,
  float& mid_band_energy,
  float& high_band_energy
) {
  const int bins = WINDOW_SAMPLES / 2 + 1;
  float max_magnitude = -1.0f;
  int peak_index = 0;
  float magnitude_sum = 0.0f;
  float weighted_sum = 0.0f;
  low_band_energy = 0.0f;
  mid_band_energy = 0.0f;
  high_band_energy = 0.0f;
  for (int k = 0; k < bins; k++) {
    double real_part = 0.0;
    double imag_part = 0.0;
    for (int n = 0; n < WINDOW_SAMPLES; n++) {
      double angle = -2.0 * PI * (double)k * (double)n / (double)WINDOW_SAMPLES;
      real_part += (double)audio[n] * cos(angle);
      imag_part += (double)audio[n] * sin(angle);
    }
    float magnitude = (float)sqrt(real_part * real_part + imag_part * imag_part);
    float freq = ((float)k * SAMPLE_RATE) / WINDOW_SAMPLES;
    float power = magnitude * magnitude;
    if (magnitude > max_magnitude) {
      max_magnitude = magnitude;
      peak_index = k;
    }
    magnitude_sum += magnitude;
    weighted_sum += freq * magnitude;
    if (freq < 1000.0f) {
      low_band_energy += power;
    } else if (freq < 4000.0f) {
      mid_band_energy += power;
    } else if (freq <= 8000.0f) {
      high_band_energy += power;
    }
  }
  peak_frequency_hz = ((float)peak_index * SAMPLE_RATE) / WINDOW_SAMPLES;
  spectral_centroid_hz = (magnitude_sum > 0.0f) ? (weighted_sum / magnitude_sum) : 0.0f;
}
void calibrateVibrationBaseline() {
#if USE_VIBRATION_ASSIST && VIBRATION_SENSOR_IS_PIEZO
  long baselineSum = 0;
  for (int i = 0; i < PIEZO_CALIBRATION_SAMPLES; i++) {
    int burstSum = 0;
    for (int j = 0; j < PIEZO_SAMPLE_BURST; j++) {
      burstSum += analogRead(VIBRATION_PIN);
      delayMicroseconds(250);
    }
    baselineSum += (burstSum / PIEZO_SAMPLE_BURST);
    delay(5);
  }
  vibrationBaseline = (int)(baselineSum / PIEZO_CALIBRATION_SAMPLES);
  vibrationBaselineReady = true;
  vibrationLastRaw = vibrationBaseline;
  vibrationLastDelta = 0;
  vibrationHeldDelta = 0;
  vibrationPeakDelta = 0;
  vibrationSpikeHoldUntilMs = 0;
#elif USE_VIBRATION_ASSIST
  long baselineSum[3] = {0, 0, 0};
  for (int i = 0; i < GY61_CALIBRATION_SAMPLES; i++) {
    long burstSum[3] = {0, 0, 0};
    for (int j = 0; j < GY61_SAMPLE_BURST; j++) {
      for (int axis = 0; axis < 3; axis++) {
        burstSum[axis] += analogRead(gy61Pins[axis]);
      }
      delayMicroseconds(250);
    }
    for (int axis = 0; axis < 3; axis++) {
      baselineSum[axis] += burstSum[axis] / GY61_SAMPLE_BURST;
    }
    delay(5);
  }
  for (int axis = 0; axis < 3; axis++) {
    gy61Baseline[axis] = (int)(baselineSum[axis] / GY61_CALIBRATION_SAMPLES);
    gy61LastRaw[axis] = gy61Baseline[axis];
  }
  vibrationBaseline =
    (gy61Baseline[0] + gy61Baseline[1] + gy61Baseline[2]) / 3;
  vibrationBaselineReady = true;
  vibrationLastRaw = 0;
  vibrationLastDelta = 0;
  vibrationHeldDelta = 0;
  vibrationPeakDelta = 0;
  vibrationSpikeHoldUntilMs = 0;
#endif
}
// Sample the vibration sensor and refresh the short helper gate.
void updateVibrationState() {
#if USE_VIBRATION_ASSIST
#if VIBRATION_SENSOR_IS_PIEZO
  int localPeakDelta = 0;
  int localLastRaw = 0;
  float localDeltaSum = 0.0f;
  float localActiveDeltaSum = 0.0f;
  float localActiveDeltaSquareSum = 0.0f;
  int localActiveCount = 0;
  for (int i = 0; i < PIEZO_SAMPLE_BURST; i++) {
    int raw = analogRead(VIBRATION_PIN);
    localLastRaw = raw;
    if (!vibrationBaselineReady) {
      vibrationBaseline = raw;
      vibrationBaselineReady = true;
    }
    int delta = abs(raw - vibrationBaseline);
    localDeltaSum += delta;
    if (delta > localPeakDelta) {
      localPeakDelta = delta;
    }
    if (delta >= VIBRATION_FEATURE_ACTIVITY_DELTA) {
      localActiveDeltaSum += delta;
      localActiveDeltaSquareSum += (float)delta * (float)delta;
      localActiveCount++;
    }
    if (delta <= PIEZO_BASELINE_UPDATE_LIMIT) {
      vibrationBaseline =
        (int)((1.0f - PIEZO_BASELINE_ALPHA) * vibrationBaseline +
              PIEZO_BASELINE_ALPHA * raw);
    }
  }
  vibrationLastRaw = localLastRaw;
  if (localPeakDelta >= PIEZO_HIT_THRESHOLD) {
    vibrationHeldDelta = localPeakDelta;
    vibrationSpikeHoldUntilMs = millis() + VIBRATION_SPIKE_HOLD_MS;
  } else if (millis() >= vibrationSpikeHoldUntilMs) {
    vibrationHeldDelta = 0;
  }
  vibrationLastDelta = localPeakDelta > vibrationHeldDelta
    ? localPeakDelta
    : vibrationHeldDelta;
  float localBurstMean = localDeltaSum / PIEZO_SAMPLE_BURST;
  float localActiveMean = 0.0f;
  float localVariance = 0.0f;
  if (localActiveCount > 0) {
    localActiveMean = localActiveDeltaSum / localActiveCount;
    float meanSquare = localActiveDeltaSquareSum / localActiveCount;
    localVariance = meanSquare - (localActiveMean * localActiveMean);
    if (localVariance < 0.0f) {
      localVariance = 0.0f;
    }
  }
  updateEngineeredVibrationFeatures(
    (float)localPeakDelta,
    localActiveMean,
    localVariance,
    localBurstMean
  );
  if (vibrationLastDelta > vibrationPeakDelta) {
    vibrationPeakDelta = vibrationLastDelta;
  }
  if (localPeakDelta >= PIEZO_HIT_THRESHOLD) {
    vibrationHoldUntilMs = millis() + VIBRATION_HOLD_MS;
    vibrationEdgeCount++;
  }
#else
  int localPeakDelta = 0;
  float localDeltaSum = 0.0f;
  float localActiveDeltaSum = 0.0f;
  float localActiveDeltaSquareSum = 0.0f;
  int localActiveCount = 0;
  for (int i = 0; i < GY61_SAMPLE_BURST; i++) {
    int raw[3] = {0, 0, 0};
    for (int axis = 0; axis < 3; axis++) {
      raw[axis] = analogRead(gy61Pins[axis]);
      gy61LastRaw[axis] = raw[axis];
    }
    if (!vibrationBaselineReady) {
      for (int axis = 0; axis < 3; axis++) {
        gy61Baseline[axis] = raw[axis];
      }
      vibrationBaselineReady = true;
    }
    float deltaMagnitudeSquared = 0.0f;
    for (int axis = 0; axis < 3; axis++) {
      int axisDelta = abs(raw[axis] - gy61Baseline[axis]);
      deltaMagnitudeSquared += (float)axisDelta * (float)axisDelta;
    }
    float rawDeltaMagnitude = sqrtf(deltaMagnitudeSquared);
    int scaledDelta = (int)lroundf(rawDeltaMagnitude * GY61_DELTA_SCALE);
    localDeltaSum += scaledDelta;
    if (scaledDelta > localPeakDelta) {
      localPeakDelta = scaledDelta;
    }
    if (scaledDelta >= VIBRATION_FEATURE_ACTIVITY_DELTA) {
      localActiveDeltaSum += scaledDelta;
      localActiveDeltaSquareSum += (float)scaledDelta * (float)scaledDelta;
      localActiveCount++;
    }
    if (rawDeltaMagnitude <= GY61_BASELINE_UPDATE_LIMIT) {
      for (int axis = 0; axis < 3; axis++) {
        gy61Baseline[axis] =
          (int)((1.0f - GY61_BASELINE_ALPHA) * gy61Baseline[axis] +
                GY61_BASELINE_ALPHA * raw[axis]);
      }
    }
    delayMicroseconds(250);
  }
  vibrationBaseline =
    (gy61Baseline[0] + gy61Baseline[1] + gy61Baseline[2]) / 3;
  vibrationLastRaw = localPeakDelta;
  if (localPeakDelta >= GY61_HIT_THRESHOLD) {
    vibrationHeldDelta = localPeakDelta;
    vibrationSpikeHoldUntilMs = millis() + VIBRATION_SPIKE_HOLD_MS;
  } else if (millis() >= vibrationSpikeHoldUntilMs) {
    vibrationHeldDelta = 0;
  }
  vibrationLastDelta = localPeakDelta > vibrationHeldDelta
    ? localPeakDelta
    : vibrationHeldDelta;
  float localBurstMean = localDeltaSum / GY61_SAMPLE_BURST;
  float localActiveMean = 0.0f;
  float localVariance = 0.0f;
  if (localActiveCount > 0) {
    localActiveMean = localActiveDeltaSum / localActiveCount;
    float meanSquare = localActiveDeltaSquareSum / localActiveCount;
    localVariance = meanSquare - (localActiveMean * localActiveMean);
    if (localVariance < 0.0f) {
      localVariance = 0.0f;
    }
  }
  updateEngineeredVibrationFeatures(
    (float)localPeakDelta,
    localActiveMean,
    localVariance,
    localBurstMean
  );
  if (vibrationLastDelta > vibrationPeakDelta) {
    vibrationPeakDelta = vibrationLastDelta;
  }
  if (localPeakDelta >= GY61_HIT_THRESHOLD) {
    vibrationHoldUntilMs = millis() + VIBRATION_HOLD_MS;
    vibrationEdgeCount++;
  }
#endif
#endif
}
