// Main pipeline: capture audio, extract features, run the model, then apply leak rules.
void runLiveModel() {
  if (!readMicWindow()) {
    Serial.println("Mic read failed");
    setLeakOutputs(LEAK_LEVEL_NONE);
    delay(20);
    return;
  }
  float features[FEATURE_COUNT] = {0.0f};
  float normalized[FEATURE_COUNT] = {0.0f};
  features[0] = computeRms(audio_i16);
  computeSpectralFeatures(
    audio_i16,
    features[1],
    features[2],
    features[3],
    features[4],
    features[5]
  );
  features[6] = computeZeroCrossingRate(audio_i16);
  updateVibrationState();
  updateEnvironmentState();
  features[9] = vibrationMagnitudeFeature;
  features[10] = vibrationMeanFeature;
  features[11] = vibrationVarianceFeature;
  features[12] = vibrationTrendFeature;
  normalize_features(features, normalized);
  // The deployed model was tuned without meaningful vibration scaling, so keep
  // those slots neutral while we use the engineered vibration features in the
  // rule-based demo layer and serial logs.
  for (int i = 9; i < FEATURE_COUNT; i++) {
    normalized[i] = 0.0f;
  }
  TfLiteTensor* input = interpreter->input(0);
  for (int i = 0; i < FEATURE_COUNT; i++) {
    input->data.f[i] = normalized[i];
  }
  if (interpreter->Invoke() != kTfLiteOk) {
    Serial.println("Model invoke failed");
    setLeakOutputs(LEAK_LEVEL_NONE);
    delay(20);
    return;
  }
  float probability = interpreter->output(0)->data.f[0];
  // The model gives leak likelihood; these rules decide confidence and leak size.
  bool vibrationGate = vibrationTriggered();
  int vibrationPinState = HIGH;
  bool vibrationRawActive = false;
#if USE_VIBRATION_ASSIST
#if VIBRATION_SENSOR_IS_PIEZO
  vibrationPinState = vibrationLastRaw;
  vibrationRawActive = vibrationLastDelta >= PIEZO_HIT_THRESHOLD;
#else
  vibrationPinState = vibrationLastRaw;
  vibrationRawActive = vibrationLastDelta >= GY61_HIT_THRESHOLD;
#endif
#endif
  bool signalFault =
    (features[0] >= MAX_VALID_SOUND_LEVEL) ||
    (clippedSampleCount >= MAX_CLIPPED_SAMPLES);
  bool vibrationMediumPattern = vibrationSupportsMedium(
    vibrationLastDelta,
    vibrationMeanFeature,
    vibrationVarianceFeature,
    vibrationTrendFeature,
    vibrationSustainFeature
  );
  bool vibrationLargePattern = vibrationSupportsLarge(
    vibrationLastDelta,
    vibrationMeanFeature,
    vibrationVarianceFeature,
    vibrationTrendFeature,
    vibrationSustainFeature
  );
  bool normalFlowBaseline = isClampNormalFlowBaseline(
    features[0],
    features[2],
    features[6],
    probability,
    vibrationLastDelta,
    vibrationMeanFeature,
    vibrationSustainFeature
  );
  bool largeLeakFlowOverride =
    !signalFault &&
    isClampLargeLeakInFlow(
      features[0],
      features[2],
      features[6],
      probability,
      vibrationLastDelta,
      vibrationMeanFeature,
      vibrationTrendFeature,
      vibrationSustainFeature
    );
  bool smallLeakFlowOverride =
    !signalFault &&
    !largeLeakFlowOverride &&
    isClampSmallLeakInFlow(
      features[0],
      features[2],
      features[6],
      probability,
      vibrationSustainFeature
    );
  normalFlowBaseline = normalFlowBaseline && !smallLeakFlowOverride && !largeLeakFlowOverride;
  bool nearNormalFlowBaseline =
    !signalFault &&
    !smallLeakFlowOverride &&
    !largeLeakFlowOverride &&
    isClampNearNormalFlowBaseline(
      features[0],
      features[2],
      features[6],
      probability,
      vibrationSustainFeature
    );
  normalFlowBaseline = normalFlowBaseline || nearNormalFlowBaseline;
  // threshold: live large-preview version of the large transition pattern
  bool largeLeakPreview =
    !signalFault &&
    !normalFlowBaseline &&
    (
      (
        (features[0] >= 16000.0f) &&
        (features[2] >= 2800.0f) &&
        (features[6] >= 0.19f) &&
        (probability >= 0.80f)
      ) ||
      (
        (features[0] >= 19000.0f) &&
        (features[2] >= 2550.0f) &&
        (features[6] >= 0.20f) &&
        (probability >= 0.60f)
      )
    );
  bool audioGate =
    (features[0] >= MIN_SOUND_LEVEL) &&
    (features[6] >= MIN_ZERO_CROSS_RATE) &&
    !signalFault &&
    !normalFlowBaseline;
  bool strongModelGate = probability >= STRONG_LEAK_THRESHOLD;
  bool assistModelGate = probability >= ASSIST_LEAK_THRESHOLD;
  bool featureAssistGate =
    (features[2] >= ASSIST_SPECTRAL_CENTER) &&
    (features[6] >= ASSIST_ZERO_CROSS_RATE);
  bool strongCandidate = audioGate && strongModelGate;
  bool assistedCandidate =
    audioGate &&
    vibrationGate &&
    (vibrationMediumPattern || (vibrationLastDelta >= 80)) &&
    assistModelGate &&
    featureAssistGate;
  bool candidateLeak = strongCandidate || assistedCandidate;
  int requiredConsecutive = vibrationGate ?
    REQUIRED_CONSECUTIVE_WITH_VIBRATION :
    REQUIRED_CONSECUTIVE_STRONG;
#if !USE_VIBRATION_ASSIST
  requiredConsecutive = 1;
#endif
  if (candidateLeak) {
    consecutiveLeakCount++;
  } else {
    consecutiveLeakCount = 0;
  }
  if (signalFault) {
    consecutiveLeakCount = 0;
  }
  bool leakDetected = consecutiveLeakCount >= requiredConsecutive;
  bool vibrationAssist = vibrationGate || vibrationRawActive;
  bool demoAcousticGate =
    !signalFault &&
    !normalFlowBaseline &&
    (features[0] >= DEMO_SOUND_LEVEL) &&
    (features[2] >= DEMO_SPECTRAL_CENTER) &&
    (features[6] >= DEMO_ZERO_CROSS_RATE);
  bool modelBurst =
    !signalFault &&
    !normalFlowBaseline &&
    (probability >= DEMO_MODEL_THRESHOLD);
  // Extra burst rules help the demo react faster to known small/medium/large patterns.
  bool smallLeakWhistleBurst =
    !signalFault &&
    !normalFlowBaseline &&
    !vibrationAssist &&
    (features[0] >= SMALL_LEAK_WHISTLE_SOUND_LEVEL) &&
    (features[2] >= SMALL_LEAK_WHISTLE_SPECTRAL_CENTER) &&
    (features[6] >= SMALL_LEAK_WHISTLE_ZERO_CROSS_RATE) &&
    (probability >= SMALL_LEAK_WHISTLE_MODEL_THRESHOLD);
  // threshold: keep medium displayed when the signal stays around 12k+/2150+/0.16+
  bool mediumDisplaySustain =
    (displayedLeakLevel == LEAK_LEVEL_MEDIUM) &&
    !signalFault &&
    !normalFlowBaseline &&
    (features[0] >= 13000.0f) &&
    (features[2] >= 2250.0f) &&
    (features[6] >= 0.16f) &&
    (
      (probability >= 0.45f) ||
      ((probability >= 0.30f) && vibrationMediumPattern)
    );
  bool displaySustainEvidence =
    !signalFault &&
    !normalFlowBaseline &&
    (
      (
        (features[0] >= DISPLAY_SUSTAIN_SOUND_LEVEL) &&
        (features[2] >= DISPLAY_SUSTAIN_SPECTRAL_CENTER) &&
        (features[6] >= DISPLAY_SUSTAIN_ZERO_CROSS_RATE) &&
        (probability >= DISPLAY_SUSTAIN_MODEL_THRESHOLD)
      ) ||
      (
        vibrationAssist &&
        (probability >= ASSIST_LEAK_THRESHOLD) &&
        featureAssistGate
      ) ||
      mediumDisplaySustain
    );
  // threshold: keep large displayed when the signal stays around 17k+/2500+/0.19+
  bool largeDisplaySustain =
    (displayedLeakLevel == LEAK_LEVEL_LARGE) &&
    !signalFault &&
    !normalFlowBaseline &&
    (features[0] >= 17000.0f) &&
    (features[2] >= 2500.0f) &&
    (features[6] >= 0.19f) &&
    (
      (probability >= 0.35f) ||
      ((probability >= 0.15f) && vibrationLargePattern)
    );
  displaySustainEvidence =
    displaySustainEvidence ||
    largeDisplaySustain;
  // threshold: direct small-leak burst reserved for whistle-like or flow-sustain signatures
  bool smallLeakDirectBurst =
    smallLeakWhistleBurst ||
    smallLeakFlowOverride;
  // threshold: direct medium-leak burst bands in the normal working range
  bool mediumLeakDirectBurst =
    !signalFault &&
    !normalFlowBaseline &&
    (
      (
        (features[0] >= 15000.0f) &&
        (features[2] >= 2400.0f) &&
        (features[6] >= 0.16f) &&
        (probability >= 0.88f)
      ) ||
      (
        (features[0] >= 12500.0f) &&
        (features[2] >= 2300.0f) &&
        (features[6] >= 0.16f) &&
        (probability >= 0.82f) &&
        vibrationMediumPattern
      ) ||
      (
        (features[0] >= 13500.0f) &&
        (features[2] >= 2150.0f) &&
        (features[6] >= 0.16f) &&
        (probability >= 0.70f) &&
        (vibrationLastDelta >= 180) &&
        !largeLeakPreview
      )
    );
  // threshold: direct large-leak burst bands for the strongest jet-like events
  bool largeLeakBurst =
    largeLeakFlowOverride ||
    (
      !signalFault &&
      !normalFlowBaseline &&
      (
        (
          (features[0] >= LARGE_LEAK_SOUND_LEVEL) &&
          (probability >= 0.95f) &&
          (features[6] >= 0.14f) &&
          (features[2] >= 2200.0f)
        ) ||
        (
          (features[0] >= 26000.0f) &&
          (features[2] >= 3000.0f) &&
          (features[6] >= 0.30f) &&
          (probability >= 0.98f)
        ) ||
        (
          (features[0] >= 22000.0f) &&
          (features[2] >= 2900.0f) &&
          (features[6] >= 0.30f) &&
          (probability >= 0.98f)
        ) ||
        (
          (features[0] >= 15000.0f) &&
          (features[2] >= 2500.0f) &&
          (features[6] >= 0.19f) &&
          (probability >= 0.75f) &&
          vibrationLargePattern
        ) ||
        largeLeakPreview
      )
    );
#if USE_VIBRATION_ASSIST
  bool assistBurst =
    vibrationAssist &&
    !normalFlowBaseline &&
    demoAcousticGate &&
    featureAssistGate &&
    (vibrationMediumPattern || (vibrationLastDelta >= 80)) &&
    modelBurst;
  bool demoLeakInstant =
    (
      leakDetected ||
      smallLeakDirectBurst ||
      mediumLeakDirectBurst ||
      largeLeakBurst ||
      assistBurst ||
      smallLeakWhistleBurst
    );
#else
  bool demoLeakInstant =
    strongCandidate ||
    smallLeakDirectBurst ||
    mediumLeakDirectBurst ||
    largeLeakBurst ||
    (demoAcousticGate && modelBurst) ||
    smallLeakWhistleBurst;
#endif
  if (signalFault || normalFlowBaseline) {
    largeLeakBurstCount = 0;
  } else if (largeLeakBurst) {
    largeLeakBurstCount++;
  } else {
    largeLeakBurstCount = 0;
  }
  bool largeLeakConfirmed =
    largeLeakFlowOverride ||
    (largeLeakBurstCount >= LARGE_BURST_CONFIRM_COUNT);
  if (normalFlowBaseline) {
    demoLeakInstant = false;
    demoLeakCount = 0;
    largeLeakBurstCount = 0;
    consecutiveLeakCount = 0;
  }
  if (demoLeakInstant) {
    demoLeakCount++;
  } else {
    demoLeakCount = 0;
  }
#if USE_VIBRATION_ASSIST
  bool demoLeak =
    leakDetected ||
    smallLeakDirectBurst ||
    largeLeakConfirmed ||
    (demoLeakCount >= DEMO_CONFIRM_COUNT);
#else
  bool demoLeak =
    leakDetected ||
    smallLeakDirectBurst ||
    largeLeakConfirmed ||
    (demoLeakCount >= DEMO_CONFIRM_COUNT);
#endif
  // Hold the strongest detected size briefly so the LED is easier to see.
  // Only capture leak size from frames that actively confirm a leak.
  // This avoids mixing unrelated later spikes into the held display event.
  bool severityEvidence =
    demoLeakInstant ||
    leakDetected ||
    demoLeak;
  bool holdingLargeLeak =
    (displayedLeakLevel == LEAK_LEVEL_LARGE) &&
    (millis() < displayLeakHoldUntilMs);
  if (largeLeakFlowOverride) {
    eventPeakLeakLevel = LEAK_LEVEL_LARGE;
  } else if (
    smallLeakFlowOverride &&
    !holdingLargeLeak &&
    (eventPeakLeakLevel < LEAK_LEVEL_LARGE)
  ) {
    eventPeakLeakLevel = LEAK_LEVEL_SMALL;
  } else if (severityEvidence) {
    updateLeakEventPeaks(
      features[0],
      features[2],
      features[6],
      probability,
      vibrationLastDelta,
      vibrationMeanFeature,
      vibrationVarianceFeature,
      vibrationTrendFeature,
      vibrationSustainFeature
    );
  }
  LeakLevel instantLeakLevel = LEAK_LEVEL_NONE;
  if (severityEvidence) {
    instantLeakLevel = eventPeakLeakLevel;
  }
  bool classifiedLeakNow = instantLeakLevel != LEAK_LEVEL_NONE;
  if (demoLeak && classifiedLeakNow) {
    displayedLeakLevel = instantLeakLevel;
    displayLeakHoldUntilMs = millis() + DISPLAY_LEAK_HOLD_MS;
  } else if (
    (displayedLeakLevel != LEAK_LEVEL_NONE) &&
    displaySustainEvidence
  ) {
    if (instantLeakLevel != LEAK_LEVEL_NONE) {
      displayedLeakLevel = instantLeakLevel;
    }
    displayLeakHoldUntilMs = millis() + DISPLAY_LEAK_HOLD_MS;
  } else if (millis() >= displayLeakHoldUntilMs) {
    displayedLeakLevel = LEAK_LEVEL_NONE;
    resetLeakEventPeaks();
  }
  bool heldFlowLeak =
    (
      (displayedLeakLevel == LEAK_LEVEL_SMALL) ||
      (displayedLeakLevel == LEAK_LEVEL_LARGE)
    ) &&
    (millis() < displayLeakHoldUntilMs);
  if (normalFlowBaseline && !heldFlowLeak) {
    displayedLeakLevel = LEAK_LEVEL_NONE;
    displayLeakHoldUntilMs = 0;
    resetLeakEventPeaks();
  }
  unsigned long nowMs = millis();
  bool alarmEvidence =
    (demoLeak && classifiedLeakNow) ||
    (
      (displayedLeakLevel != LEAK_LEVEL_NONE) &&
      displaySustainEvidence
    );
  if (alarmEvidence) {
    if ((instantLeakLevel != LEAK_LEVEL_NONE) && (instantLeakLevel > alarmedLeakLevel)) {
      alarmedLeakLevel = instantLeakLevel;
    } else if ((alarmedLeakLevel == LEAK_LEVEL_NONE) && (displayedLeakLevel != LEAK_LEVEL_NONE)) {
      alarmedLeakLevel = displayedLeakLevel;
    }
    alarmLeakHoldUntilMs = nowMs + ALARM_LATCH_MIN_MS;
    alarmQuietSinceMs = 0;
  } else if (alarmedLeakLevel != LEAK_LEVEL_NONE) {
    if (alarmQuietSinceMs == 0) {
      alarmQuietSinceMs = nowMs;
    }
    if (
      (nowMs >= alarmLeakHoldUntilMs) &&
      ((nowMs - alarmQuietSinceMs) >= ALARM_CLEAR_QUIET_MS)
    ) {
      alarmedLeakLevel = LEAK_LEVEL_NONE;
      alarmLeakHoldUntilMs = 0;
      alarmQuietSinceMs = 0;
    }
  }
  LeakLevel outputLeakLevel = alarmedLeakLevel != LEAK_LEVEL_NONE ? alarmedLeakLevel : displayedLeakLevel;
  bool displayLeak = outputLeakLevel != LEAK_LEVEL_NONE;
  setLeakOutputs(outputLeakLevel, signalFault);
#if ENABLE_AWS_IOT
  publishLeakTelemetry(
    features[0],
    features[1],
    features[2],
    features[6],
    probability,
    vibrationLastDelta,
    vibrationMeanFeature,
    vibrationVarianceFeature,
    vibrationTrendFeature,
    vibrationSustainFeature,
    outputLeakLevel,
    displayLeak
  );
#endif
   updateLocalDisplay(
    outputLeakLevel,
    probability,
    features[0],
    vibrationLastDelta
  );
  if (millis() - lastPrintMs >= PRINT_INTERVAL_MS) {
#if PRESENTATION_SERIAL_OUTPUT
    unsigned long nowMs = millis();
    static bool presentationStateReady = false;
    static LeakLevel lastPresentedLeakLevel = LEAK_LEVEL_NONE;
    if (!presentationStateReady) {
