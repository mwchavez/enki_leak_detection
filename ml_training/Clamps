void setup() {
  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0);
  Serial.begin(115200);
  delay(1000);
  Serial.println("BUILD: Clamp02 leak_tune_2026-04-30-r4");
  Serial.print("PROFILE: ");
  Serial.println(DEVICE_PROFILE_NAME);
  Serial.print("DISPLAY: ");
  Serial.println(PRESENTATION_NODE_LABEL);
  Serial.println("TIMER: serial:t/time/timer");
  Serial.println("CFG: assist_spec=2200 assist_zcr=0.14 burst_confirm=2 large_spec=2200 large_zcr=0.14");
  Serial.println("CFG2: alarm_latch=10000 quiet_clear=5000");
#if USE_RGB_LEAK_LED
  pinMode(RGB_RED_PIN, OUTPUT);
  pinMode(RGB_GREEN_PIN, OUTPUT);
  pinMode(RGB_BLUE_PIN, OUTPUT);
#else
  pinMode(SMALL_LED_PIN, OUTPUT);
#if USE_LEAK_LEVEL_LEDS
  pinMode(MEDIUM_LED_PIN, OUTPUT);
  pinMode(LARGE_LED_PIN, OUTPUT);
#endif
#endif
  setLeakOutputs(LEAK_LEVEL_NONE);
#if USE_VIBRATION_ASSIST
#if VIBRATION_SENSOR_IS_PIEZO
  pinMode(VIBRATION_PIN, INPUT_PULLDOWN);
#if defined(ESP32)
  analogReadResolution(12);
#endif
  Serial.println("Calibrating vibration baseline...");
  calibrateVibrationBaseline();
  Serial.print("Vibration baseline: ");
  Serial.println(vibrationBaseline);
#else
  pinMode(GY61_X_PIN, INPUT);
  pinMode(GY61_Y_PIN, INPUT);
  pinMode(GY61_Z_PIN, INPUT);
#if defined(ESP32)
  analogReadResolution(12);
#if defined(ADC_11db)
  analogSetPinAttenuation(GY61_X_PIN, ADC_11db);
  analogSetPinAttenuation(GY61_Y_PIN, ADC_11db);
  analogSetPinAttenuation(GY61_Z_PIN, ADC_11db);
#endif
#endif
  Serial.println("Calibrating GY-61 baseline...");
  calibrateVibrationBaseline();
  Serial.print("GY-61 baseline XYZ: ");
  Serial.print(gy61Baseline[0]);
  Serial.print("/");
  Serial.print(gy61Baseline[1]);
  Serial.print("/");
  Serial.println(gy61Baseline[2]);
#endif
#endif
  setupI2CBus();
  setupDisplay();
  setupEnvironmentSensor();
  setupMic();
  setupModel();
  presentationClockStartMs = millis();
#if ENABLE_AWS_IOT
  connectAWS();
#endif
  Serial.println("Leak detector ready");
#if USE_RGB_LEAK_LED
  Serial.println("LEDs: green=on, red=small, yellow=medium, blue=large");
#elif USE_LEAK_LEVEL_LEDS
  Serial.println("LED levels: small, medium, large");
#else
  Serial.println("Single leak LED enabled");
#endif
#if USE_VIBRATION_ASSIST
#if VIBRATION_SENSOR_IS_PIEZO
  Serial.println("Fusion: audio + vibration");
#else
  Serial.println("Fusion: audio + vibration (GY-61)");
#endif
#else
  Serial.println("Fusion: audio only");
#endif
#if USE_OLED_DISPLAY
  if (oledDisplayReady) {
    Serial.print("OLED: ready @ 0x");
    if (oledI2CAddressInUse < 16) {
      Serial.print("0");
    }
    Serial.println(oledI2CAddressInUse, HEX);
  } else {
    Serial.println("OLED: init failed");
  }
#else
  Serial.println("OLED: disabled");
#endif
#if USE_BME680_ENV_SENSOR
  Serial.println(envSensorReady ? "BME680: ready" : "BME680: init failed");
#else
  Serial.println("BME680: library missing");
#endif
#if ENABLE_AWS_IOT
  Serial.println("AWS: enabled");
#else
  Serial.println("AWS: local-only mode");
#endif
  Serial.println();
}
void loop() {
  if (handleSerialCommands()) {
    delay(5);
    return;
  }
#if ENABLE_AWS_IOT
  if (!client.connected()) {
    connectAWS();
  }
  client.loop();
#endif
  runLiveModel();
  delay(5);
}

