void printElapsedPrefix(unsigned long nowMs) {
  unsigned long elapsedMs = nowMs - presentationClockStartMs;
  unsigned long totalSeconds = elapsedMs / 1000UL;
  unsigned long minutes = totalSeconds / 60UL;
  unsigned long seconds = totalSeconds % 60UL;
  Serial.print("T+");
  if (minutes < 10UL) {
    Serial.print("0");
  }
  Serial.print(minutes);
  Serial.print(":");
  if (seconds < 10UL) {
    Serial.print("0");
  }
  Serial.print(seconds);
  Serial.print(" | ");
}

void resetPresentationClock() {
  presentationClockStartMs = millis();
  lastPrintMs = 0;
  Serial.println("TIMER: reset to T+00:00");
}

bool handleSerialCommands() {
  if (!Serial.available()) {
    return false;
  }

  String command = Serial.readStringUntil('\n');
  command.trim();
  command.toLowerCase();

  if (command == "t" || command == "time" || command == "timer") {
    resetPresentationClock();
    return true;
  }

  return false;
}
