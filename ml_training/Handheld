bool readMicWindow() {
  size_t bytesRead = 0;
  esp_err_t result = i2s_read(
    I2S_PORT,
    rawSamples,
    sizeof(rawSamples),
    &bytesRead,
    pdMS_TO_TICKS(I2S_READ_TIMEOUT_MS)
  );

  if (result != ESP_OK || bytesRead != sizeof(rawSamples)) {
    micReadFailCount++;
    if (micReadFailCount >= MIC_FAIL_RESET_COUNT) {
      i2s_zero_dma_buffer(I2S_PORT);
      micReadFailCount = 0;
    }
    return false;
  }
  micReadFailCount = 0;

  long long sum = 0;
  for (int i = 0; i < WINDOW_SAMPLES; i++) {
    sum += rawSamples[i];
  }
  int32_t mean = (int32_t)(sum / WINDOW_SAMPLES);

  clippedSampleCount = 0;
  for (int i = 0; i < WINDOW_SAMPLES; i++) {
    int32_t centered = rawSamples[i] - mean;
    int32_t shifted = centered >> 8;
    if (shifted > 32767) {
      shifted = 32767;
    }
    if (shifted < -32768) {
      shifted = -32768;
    }
    audioI16[i] = (int16_t)shifted;
    if (abs((int)audioI16[i]) >= 32760) {
      clippedSampleCount++;
    }
  }

  return true;
}

float computeRms(const int16_t* audio) {
  double sumSq = 0.0;
  for (int i = 0; i < WINDOW_SAMPLES; i++) {
    double value = (double)audio[i];
    sumSq += value * value;
  }
  return (float)sqrt(sumSq / WINDOW_SAMPLES + 1e-12);
}

float computeZeroCrossingRate(const int16_t* audio) {
  int crossings = 0;
  for (int i = 1; i < WINDOW_SAMPLES; i++) {
    bool previousPositive = audio[i - 1] >= 0;
    bool currentPositive = audio[i] >= 0;
    if (previousPositive != currentPositive) {
      crossings++;
    }
  }
  return (float)crossings / (float)(WINDOW_SAMPLES - 1);
}

void computeSpectralFeatures(
  const int16_t* audio,
  float& peakFrequency,
  float& spectralCentroid,
  float& lowBandEnergy,
  float& midBandEnergy,
  float& highBandEnergy
) {
  const int bins = WINDOW_SAMPLES / 2 + 1;
  float maxMagnitude = -1.0f;
  int peakIndex = 0;
  float magnitudeSum = 0.0f;
  float weightedSum = 0.0f;

  lowBandEnergy = 0.0f;
  midBandEnergy = 0.0f;
  highBandEnergy = 0.0f;

  for (int k = 0; k < bins; k++) {
    double realPart = 0.0;
    double imagPart = 0.0;

    for (int n = 0; n < WINDOW_SAMPLES; n++) {
      double angle =
        -2.0 * PI * (double)k * (double)n / (double)WINDOW_SAMPLES;
      realPart += (double)audio[n] * cos(angle);
      imagPart += (double)audio[n] * sin(angle);
    }

    float magnitude = (float)sqrt(realPart * realPart + imagPart * imagPart);
    float frequency = ((float)k * SAMPLE_RATE) / WINDOW_SAMPLES;
    float power = magnitude * magnitude;

    if (magnitude > maxMagnitude) {
      maxMagnitude = magnitude;
      peakIndex = k;
    }

    magnitudeSum += magnitude;
    weightedSum += frequency * magnitude;

    if (frequency < 1000.0f) {
      lowBandEnergy += power;
    } else if (frequency < 4000.0f) {
      midBandEnergy += power;
    } else if (frequency <= 8000.0f) {
      highBandEnergy += power;
    }
  }

  peakFrequency = ((float)peakIndex * SAMPLE_RATE) / WINDOW_SAMPLES;
  spectralCentroid = magnitudeSum > 0.0f ? weightedSum / magnitudeSum : 0.0f;
}

void calibrateVibrationBaseline() {
  long baselineSum[3] = {0, 0, 0};

  for (int sample = 0; sample < GY61_CALIBRATION_SAMPLES; sample++) {
    long burstSum[3] = {0, 0, 0};

    for (int burst = 0; burst < GY61_SAMPLE_BURST; burst++) {
      for (int axis = 0; axis < 3; axis++) {
        burstSum[axis] += analogRead(gy61Pins[axis]);
      }
      delayMicroseconds(250);
    }

    for (int axis = 0; axis < 3; axis++) {
      baselineSum[axis] += burstSum[axis] / GY61_SAMPLE_BURST;
    }
    delay(5);
  }

  for (int axis = 0; axis < 3; axis++) {
    gy61Baseline[axis] = (int)(baselineSum[axis] / GY61_CALIBRATION_SAMPLES);
    gy61LastRaw[axis] = gy61Baseline[axis];
  }
}

void updateEngineeredVibrationFeatures(
  float peakDelta,
  float activeMean,
  float variance,
  float burstMean
) {
  vibrationLastDelta = (int)peakDelta;
  vibrationMeanFeature = activeMean;
  vibrationVarianceFeature = variance;

  float trend = vibrationMeanFeature - previousVibrationMeanFeature;
  vibrationTrendFeature = trend > 0.0f ? trend : 0.0f;
  previousVibrationMeanFeature = vibrationMeanFeature;

  vibrationSustainFeature =
    (VIBRATION_SUSTAIN_ALPHA * burstMean) +
    ((1.0f - VIBRATION_SUSTAIN_ALPHA) * vibrationSustainFeature);
}

void updateVibrationState() {
  int localPeakDelta = 0;
  float localDeltaSum = 0.0f;
  float localActiveDeltaSum = 0.0f;
  float localActiveDeltaSquareSum = 0.0f;
  int localActiveCount = 0;

  for (int sample = 0; sample < GY61_SAMPLE_BURST; sample++) {
    int raw[3] = {0, 0, 0};
    for (int axis = 0; axis < 3; axis++) {
      raw[axis] = analogRead(gy61Pins[axis]);
      gy61LastRaw[axis] = raw[axis];
    }

    float deltaMagnitudeSquared = 0.0f;
    for (int axis = 0; axis < 3; axis++) {
      int axisDelta = abs(raw[axis] - gy61Baseline[axis]);
      deltaMagnitudeSquared += (float)axisDelta * (float)axisDelta;
    }

    float rawDeltaMagnitude = sqrtf(deltaMagnitudeSquared);
    int scaledDelta = (int)lroundf(rawDeltaMagnitude * GY61_DELTA_SCALE);
    localDeltaSum += scaledDelta;

    if (scaledDelta > localPeakDelta) {
      localPeakDelta = scaledDelta;
    }

    if (scaledDelta >= VIBRATION_FEATURE_ACTIVITY_DELTA) {
      localActiveDeltaSum += scaledDelta;
      localActiveDeltaSquareSum += (float)scaledDelta * (float)scaledDelta;
      localActiveCount++;
    }

    if (rawDeltaMagnitude <= GY61_BASELINE_UPDATE_LIMIT) {
      for (int axis = 0; axis < 3; axis++) {
        gy61Baseline[axis] =
          (int)((1.0f - GY61_BASELINE_ALPHA) * gy61Baseline[axis] +
                GY61_BASELINE_ALPHA * raw[axis]);
      }
    }

    delayMicroseconds(250);
  }

  float burstMean = localDeltaSum / GY61_SAMPLE_BURST;
  float activeMean = 0.0f;
  float variance = 0.0f;

  if (localActiveCount > 0) {
    activeMean = localActiveDeltaSum / localActiveCount;
    float meanSquare = localActiveDeltaSquareSum / localActiveCount;
    variance = meanSquare - (activeMean * activeMean);
    if (variance < 0.0f) {
      variance = 0.0f;
    }
  }

  updateEngineeredVibrationFeatures(
    (float)localPeakDelta,
    activeMean,
    variance,
    burstMean
  );
}

void setupI2CBuses() {
  Wire.begin(OLED_I2C_SDA_PIN, OLED_I2C_SCL_PIN);
  Wire.setClock(400000);

  bmeWire.begin(BME_I2C_SDA_PIN, BME_I2C_SCL_PIN);
