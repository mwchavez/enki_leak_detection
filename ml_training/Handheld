void setupDisplay() {
  if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_I2C_ADDRESS_PRIMARY) &&
      !display.begin(SSD1306_SWITCHCAPVCC, OLED_I2C_ADDRESS_SECONDARY)) {
    oledReady = false;
    Serial.println("OLED init failed");
    return;
  }

  oledReady = true;
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(1);
  display.setCursor(0, 0);
  display.println("Leak Detector");
  display.println("Starting...");
  display.display();
}

void setupEnvironmentSensor() {
  if (!bme680.begin(BME680_I2C_ADDRESS_PRIMARY) &&
      !bme680.begin(BME680_I2C_ADDRESS_SECONDARY)) {
    bmeReady = false;
    Serial.println("BME680 init failed");
    return;
  }

  bmeReady = true;
  bme680.setTemperatureOversampling(BME680_OS_8X);
  bme680.setHumidityOversampling(BME680_OS_2X);
  bme680.setPressureOversampling(BME680_OS_4X);
  bme680.setIIRFilterSize(BME680_FILTER_SIZE_3);
  bme680.setGasHeater(0, 0);
}

void updateEnvironmentState() {
  if (!bmeReady) {
    return;
  }

  unsigned long now = millis();
  if (lastEnvSampleMs != 0 &&
      now - lastEnvSampleMs < ENV_SAMPLE_INTERVAL_MS) {
    return;
  }

  if (!bme680.performReading()) {
    Serial.println("BME680 read failed");
    lastEnvSampleMs = now;
    return;
  }

  envTemperatureC = bme680.temperature;
  envHumidityPct = bme680.humidity;
  lastEnvSampleMs = now;
}

LeakLevel classifyLeak(
  float probability,
  float acoustic,
  float spectralCenter,
  float zcr,
  int vibrationDelta,
  float vibrationMean,
  float vibrationSustain
) {
  bool signalFault =
    (acoustic >= MAX_VALID_SOUND_LEVEL) ||
    (clippedSampleCount >= MAX_CLIPPED_SAMPLES);

  bool validAudio =
    !signalFault &&
    (acoustic >= MIN_SOUND_LEVEL) &&
    (zcr >= MIN_ZERO_CROSS_RATE);

  bool lowTextureBackground =
    !signalFault &&
    (spectralCenter < 2100.0f) &&
    (zcr < 0.10f) &&
    (probability < 0.02f);

  bool vibrationSupport =
    !signalFault &&
    (
      (vibrationDelta >= ACOUSTIC_SUPPORT_VIBRATION_DELTA_MIN) ||
      (vibrationMean >= ACOUSTIC_SUPPORT_VIBRATION_MEAN_MIN) ||
      (vibrationSustain >= ACOUSTIC_SUPPORT_VIBRATION_SUSTAIN_MIN)
    );

  bool vibrationLargeSupport =
    !signalFault &&
    (
      (vibrationDelta >= ACOUSTIC_SUPPORT_LARGE_VIBRATION_DELTA_MIN) ||
      (vibrationMean >= ACOUSTIC_SUPPORT_LARGE_VIBRATION_MEAN_MIN) ||
      (vibrationSustain >= ACOUSTIC_SUPPORT_LARGE_VIBRATION_SUSTAIN_MIN)
    ) &&
    vibrationSupport;

  bool vibrationLeakBand =
    !signalFault &&
    vibrationSupport &&
    (vibrationMean <= ACOUSTIC_SUPPORT_LEAK_MEAN_MAX) &&
    (vibrationSustain <= ACOUSTIC_SUPPORT_LEAK_SUSTAIN_MAX);

  bool contactTransient =
    !signalFault &&
    (vibrationTrendFeature >= CONTACT_TRANSIENT_TREND_MAX) &&
    (vibrationVarianceFeature <= CONTACT_TRANSIENT_VARIANCE_MAX);

  bool impulsiveAcousticBurst =
    !signalFault &&
    (acoustic <= ACOUSTIC_IMPACT_REJECT_SOUND_MAX) &&
    (spectralCenter >= ACOUSTIC_IMPACT_REJECT_SPECTRAL_MIN) &&
    (zcr >= ACOUSTIC_IMPACT_REJECT_ZERO_CROSS_MIN) &&
    (probability >= ACOUSTIC_IMPACT_REJECT_PROB_MIN);

  bool acousticLeakPrimary =
    !signalFault &&
    !contactTransient &&
    !impulsiveAcousticBurst &&
    vibrationLeakBand &&
    (acoustic >= ACOUSTIC_PRIMARY_LEAK_SOUND_MIN) &&
    (
      (
        (spectralCenter >= ACOUSTIC_PRIMARY_LEAK_SPECTRAL_MIN) &&
        (zcr >= ACOUSTIC_PRIMARY_LEAK_ZERO_CROSS_MIN) &&
        (probability >= 0.08f)
      ) ||
      (
        (probability >= ACOUSTIC_PRIMARY_LEAK_PROB_MIN) &&
        (spectralCenter >= 2300.0f)
      )
    );

  bool acousticLargePrimary =
    !signalFault &&
    !impulsiveAcousticBurst &&
    (acoustic >= ACOUSTIC_PRIMARY_LARGE_SOUND_MIN) &&
    (
      (
        (spectralCenter >= ACOUSTIC_PRIMARY_LARGE_SPECTRAL_MIN) &&
        (zcr >= ACOUSTIC_PRIMARY_LARGE_ZERO_CROSS_MIN)
      ) ||
      (probability >= ACOUSTIC_PRIMARY_LARGE_PROB_MIN)
    ) &&
    vibrationLargeSupport;

  if (lowTextureBackground) {
    return LEAK_LEVEL_NONE;
  }

  if (acousticLargePrimary) {
    return LEAK_LEVEL_LARGE;
  }

  if (acousticLeakPrimary) {
    return LEAK_LEVEL_SMALL;
  }

  if (!validAudio || probability < MODEL_LEAK_THRESHOLD) {
    return LEAK_LEVEL_NONE;
  }
  return LEAK_LEVEL_NONE;
}

LeakLevel applyLeakConfirmation(LeakLevel rawLevel) {
  if (rawLevel == LEAK_LEVEL_LARGE) {
    if (largeLeakConfirmCount < LARGE_LEAK_CONFIRM_FRAMES) {
      largeLeakConfirmCount++;
    }
    largeLeakReleaseCount = 0;
    mediumLeakConfirmCount = 0;
    smallLeakConfirmCount = 0;
    leakClearCount = 0;

    // When an active medium leak grows into a large leak, show the upgrade
    // immediately instead of forcing the OLED to sit on MEDIUM first.
    if (leakLevel == LEAK_LEVEL_MEDIUM || leakLevel == LEAK_LEVEL_LARGE) {
      return LEAK_LEVEL_LARGE;
    }

    if (largeLeakConfirmCount >= LARGE_LEAK_CONFIRM_FRAMES) {
      return LEAK_LEVEL_LARGE;
    }

    return leakLevel;
  }

  largeLeakConfirmCount = 0;

  if (leakLevel == LEAK_LEVEL_LARGE) {
    if (largeLeakReleaseCount < LARGE_LEAK_RELEASE_FRAMES) {
      largeLeakReleaseCount++;
    }

    if (largeLeakReleaseCount < LARGE_LEAK_RELEASE_FRAMES) {
      return LEAK_LEVEL_LARGE;
    }

    if (rawLevel == LEAK_LEVEL_NONE) {
      if (leakClearCount < LARGE_TO_NONE_CLEAR_FRAMES) {
        leakClearCount++;
      }
      if (leakClearCount >= LARGE_TO_NONE_CLEAR_FRAMES) {
        return LEAK_LEVEL_NONE;
      }
      return LEAK_LEVEL_LARGE;
    }
  } else {
    largeLeakReleaseCount = 0;
  }

  if (rawLevel == LEAK_LEVEL_MEDIUM) {
    if (mediumLeakConfirmCount < MEDIUM_LEAK_CONFIRM_FRAMES) {
      mediumLeakConfirmCount++;
    }
    smallLeakConfirmCount = 0;
    leakClearCount = 0;

    if (leakLevel == LEAK_LEVEL_MEDIUM) {
      return LEAK_LEVEL_MEDIUM;
    }

    if (mediumLeakConfirmCount >= MEDIUM_LEAK_CONFIRM_FRAMES) {
      return LEAK_LEVEL_MEDIUM;
    }

    return leakLevel;
  }

  mediumLeakConfirmCount = 0;

  if (rawLevel == LEAK_LEVEL_SMALL) {
    if (smallLeakConfirmCount < SMALL_LEAK_CONFIRM_FRAMES) {
      smallLeakConfirmCount++;
    }
    leakClearCount = 0;

    if (leakLevel == LEAK_LEVEL_SMALL) {
      return LEAK_LEVEL_SMALL;
    }

    if (smallLeakConfirmCount >= SMALL_LEAK_CONFIRM_FRAMES) {
      return LEAK_LEVEL_SMALL;
    }

    return leakLevel;
  }

  smallLeakConfirmCount = 0;

  if (leakClearCount < LEAK_CLEAR_FRAMES) {
    leakClearCount++;
  }

  if (leakClearCount >= LEAK_CLEAR_FRAMES) {
    return LEAK_LEVEL_NONE;
  }

  return leakLevel;
}

bool runTensorFlowModel(float features[FEATURE_COUNT], float& probability) {
  float normalized[FEATURE_COUNT] = {0.0f};
  normalize_features(features, normalized);

  normalized[7] = 0.0f;
  normalized[8] = 0.0f;

  for (int i = 9; i < FEATURE_COUNT; i++) {
    normalized[i] = 0.0f;
  }

  TfLiteTensor* input = interpreter->input(0);
  for (int i = 0; i < FEATURE_COUNT; i++) {
    input->data.f[i] = normalized[i];
  }

  if (interpreter->Invoke() != kTfLiteOk) {
    Serial.println("Model invoke failed");
    probability = 0.0f;
    return false;
  }

  probability = interpreter->output(0)->data.f[0];
  return true;
}

void updateDisplay() {
  if (!oledReady) {
    return;
  }

  unsigned long now = millis();
  if (lastDisplayRefreshMs != 0 &&
      now - lastDisplayRefreshMs < DISPLAY_REFRESH_MS) {
    return;
  }

  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);

  display.setTextSize(1);
  display.setCursor(0, 0);
  display.println("Leak Detector");

  display.setTextSize(2);
  display.setCursor(0, 12);
  if (millis() < stabilizeUntilMs) {
    display.println("STABILIZE");
  } else {
    display.println(leakLevelLabel(leakLevel));
  }

  display.setTextSize(1);
  display.setCursor(0, 34);
  display.print("A:");
  display.println((int)soundLevel);

  display.setCursor(0, 46);
  display.print("V:");
  display.print(vibrationLastDelta);
  display.print(" T:");
  if (bmeReady && !isnan(envTemperatureC)) {
    display.print(envTemperatureC, 1);
    display.print("C");
  } else {
    display.print("--.-C");
  }

  display.setCursor(0, 56);
  display.print("H:");
  if (bmeReady && !isnan(envHumidityPct)) {
    display.print(envHumidityPct, 0);
    display.print("%");
  } else {
    display.print("--%");
  }

  display.display();
  lastDisplayRefreshMs = now;
}

void printSerial() {
  unsigned long now = millis();
  if (lastSerialPrintMs != 0 && now - lastSerialPrintMs < SERIAL_PRINT_MS) {
    return;
  }
  lastSerialPrintMs = now;

  Serial.print("SoundLevel:");
  Serial.print(soundLevel, 2);
  Serial.print("\tSpectralCenter:");
  Serial.print(spectralCenterHz, 2);
  Serial.print("\tZeroCross:");
  Serial.print(zeroCrossRate, 4);
  Serial.print("\tLeakProb:");
  Serial.print(modelScore, 6);
  Serial.print("\tVibrationDelta:");
  Serial.print(vibrationLastDelta);
  Serial.print("\tVibrationMean:");
  Serial.print(vibrationMeanFeature, 2);
  Serial.print("\tVibrationVar:");
  Serial.print(vibrationVarianceFeature, 2);
  Serial.print("\tVibrationTrend:");
  Serial.print(vibrationTrendFeature, 2);
  Serial.print("\tVibrationSustain:");
  Serial.print(vibrationSustainFeature, 2);
  Serial.print("\tTempC:");
  if (bmeReady && !isnan(envTemperatureC)) {
    Serial.print(envTemperatureC, 1);
  } else {
    Serial.print("nan");
  }
  Serial.print("\tMoisture:");
  if (bmeReady && !isnan(envHumidityPct)) {
    Serial.print(envHumidityPct, 1);
  } else {
    Serial.print("nan");
  }
  Serial.print("\tLeakLevel:");
  Serial.print((int)leakLevel);
  Serial.print("\tRawLevel:");
  Serial.println((int)rawLeakLevel);
}

void runHandheldModel() {
  if (!readMicWindow()) {
    Serial.println("Mic read failed");
    leakLevel = LEAK_LEVEL_NONE;
    updateDisplay();
    delay(20);
    return;
  }

  float features[FEATURE_COUNT] = {0.0f};

  features[0] = computeRms(audioI16);
  computeSpectralFeatures(
    audioI16,
    features[1],
    features[2],
    features[3],
    features[4],
    features[5]
  );
  features[6] = computeZeroCrossingRate(audioI16);

  updateVibrationState();
  updateEnvironmentState();

  features[7] = 0.0f;
  features[8] = 0.0f;
  features[9] = vibrationLastDelta;
  features[10] = vibrationMeanFeature;
  features[11] = vibrationVarianceFeature;
  features[12] = vibrationTrendFeature;

  soundLevel = features[0];
  peakFrequencyHz = features[1];
  spectralCenterHz = features[2];
  zeroCrossRate = features[6];

  if (!runTensorFlowModel(features, modelScore)) {
    rawLeakLevel = LEAK_LEVEL_NONE;
  } else {
    rawLeakLevel = classifyLeak(
      modelScore,
      soundLevel,
      spectralCenterHz,
      zeroCrossRate,
      vibrationLastDelta,
      vibrationMeanFeature,
      vibrationSustainFeature
    );
  }

  if (millis() < stabilizeUntilMs) {
    clearLeakState();
    updateDisplay();
    printSerial();
    return;
  }

  leakLevel = applyLeakConfirmation(rawLeakLevel);

  updateDisplay();
  printSerial();
}

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println();
  Serial.println("BUILD: final_model_demo_handheld leak_tune_2026-05-04-r15");
  Serial.println("CFG: mode=acoustic_primary leak_confirm=3 large_confirm=2 large_release=3 large_clear=2 clear=12 stabilize=5000 quick_reset=serial:r/reset leak_audio=18000/2500/0.17/0.18 large_audio=17000/2700/0.20/0.35 leak_vibe=550/450/500 leak_band=950/950 large_vibe=800/650/650 kick_reject=400/5000 impact_reject=24000/3600/0.40/0.995");

  pinMode(GY61_X_PIN, INPUT);
  pinMode(GY61_Y_PIN, INPUT);
  pinMode(GY61_Z_PIN, INPUT);

#if defined(ESP32)
  analogReadResolution(12);
  analogSetPinAttenuation(GY61_X_PIN, ADC_11db);
  analogSetPinAttenuation(GY61_Y_PIN, ADC_11db);
  analogSetPinAttenuation(GY61_Z_PIN, ADC_11db);
#endif

  setupI2CBuses();
  setupDisplay();
  setupEnvironmentSensor();
  setupMic();
  setupModel();

  if (oledReady) {
    display.clearDisplay();
    display.setCursor(0, 0);
    display.setTextSize(1);
    display.println("Keep sensor still");
    display.println("Calibrating GY-61");
    display.display();
  }

  calibrateVibrationBaseline();
  updateEnvironmentState();
  stabilizeUntilMs = millis() + STARTUP_STABILIZE_MS;

  Serial.println("Ready. TensorFlow on-device. Local only.");
}

void loop() {
  if (handleSerialCommands()) {
    delay(5);
    return;
  }

  runHandheldModel();
  delay(5);
}
